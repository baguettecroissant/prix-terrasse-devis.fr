---
import { siteConfig } from '../../site.config';
---

<section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">
    Comment obtenir votre devis ?
  </h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {siteConfig.process.map((step, idx) => (
      <div class="relative text-center">
        <div class="w-14 h-14 bg-brand-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl relative">
          {step.icon}
          <span class="absolute -top-2 -right-2 w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">
            {idx + 1}
          </span>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">{step.title}</h3>
        <p class="text-sm text-gray-600">{step.desc}</p>
        {step.duration && (
          <span class="inline-block mt-2 text-xs text-brand-600 bg-brand-50 px-2 py-1 rounded-full font-medium">
            ⏱ {step.duration}
          </span>
        )}
      </div>
    ))}
  </div>
</section>
